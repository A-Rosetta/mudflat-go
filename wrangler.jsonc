{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mudflat-go",
  "main": "worker.mjs",
  "compatibility_date": "2026-07-17",
  "observability": {
    "enabled": true
  },
  "ai": {
    "binding": "AI"
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  }
}
